# Supabase — connection credentials
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Service role key — SECRET, never expose to the client!
# Find this in Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Admin token for protected routes (change this!)
ADMIN_TOKEN="your-secret-admin-token"

# Public site URL (used for sitemap, OG tags, etc.)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# z.ai LLM API (OpenAI-compatible) for auto-import deal rewriting
ZAI_API_KEY="your-zai-api-key"
ZAI_BASE_URL="https://api.z.ai/api/coding/paas/v4"
ZAI_MODEL="glm-4.5"

# Optional: Secret for verifying Vercel Cron requests.
# If set, Vercel Cron must send this as a Bearer token.
# If not set, Vercel Cron requests are allowed via the x-vercel-cron header.
# CRON_SECRET="your-cron-secret"

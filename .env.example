# Supabase — connection credentials
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Service role key — SECRET, never expose to the client!
# Find this in Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Admin token for protected routes (change this!)
ADMIN_TOKEN="your-secret-admin-token"

# Public site URL (used for sitemap, OG tags, etc.)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# z.ai LLM API (OpenAI-compatible) for auto-import deal rewriting
ZAI_API_KEY="your-zai-api-key"
ZAI_BASE_URL="https://api.z.ai/v1"
ZAI_MODEL="gpt-4o-mini"
